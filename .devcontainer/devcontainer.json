{
  "name": "Queue Application",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/app",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ritwickdey.LiveServer"
      ],
      "settings": {
        "python-envs.defaultEnvManager": "ms-python.python:system"
      }
    }
  }
}